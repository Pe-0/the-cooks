using System;
using System.Collections.Generic;
using System.Linq;
using System.Security.Cryptography.X509Certificates;
using System.Text;
using System.Threading.Tasks;

namespace ConsoleApp2
{
    public abstract class Product
    {
        protected int Id;
        protected string Name;
        protected double Price;
        protected int Quantity;
        protected string Product_Description;
        protected Product()//constractor without parameter
        {
            Id = 0;
            Name = "null";
            Price = 0;
            Quantity = 0;
            Product_Description = "null";
        }
        protected Product(int Id, string name, double Price, int quantity, string Product_Description)//constractor with parameter
        {
            ID = Id;
            NAME = name;
            PRICE = Price;
            QUANTITY = quantity;
            PRODUCT_DESCRIPTION = Product_Description;


        }
        public int ID //property for ID
        {
            set
            {
                if (value >= 0)
                {
                    this.Id = value;
                }
                else
                {
                    this.Id = 0;
                    Console.WriteLine("Error in ID number");
                }
            }
            get { return ID; }
        }

        public string NAME //property for NAME
        {
            set { Name = value; }
            get { return Name; }
        }
        public double PRICE //property for PRICE
        {
            set
            {
                if (value >= 0)
                    Price = value;
                else
                {
                    Price = 0;
                    Console.WriteLine("Price Can’t be in negative ");
                }
            }
            get { return Price; }
        }
        public int QUANTITY //prpoerty for QUANTITY
        {
            set
            {
                if (value >= 0)
                {
                    Quantity = value;
                }
                else
                {
                    Quantity = 0;
                    Console.WriteLine("Error in ID number");
                }
            }
            get { return Quantity; }
        }
        public string PRODUCT_DESCRIPTION //property for Descritption
        {
            set { Product_Description = value; }
            get { return Product_Description; }
        }

        public abstract double CalculatePrice();//abstract method
        public virtual void DisplayInfo()
        {
            Console.WriteLine("ID: " + Id + " name:" + Name + " Price:" + Price);

        }
    }
    //abstraction part (ship and discounts)
    public class Physical : Product
    {
        private double Shipping_Cost;
        private double Discount;
        public Physical()//constractor without parameter
        {
            Shipping_Cost = 0;
            Discount = 0;
        }
        public Physical(int ID, string name, float price, int quantity, string Product_Description, double Shipping_Cost, double Discount) : base(ID, name, price, quantity, Product_Description)//constractor with parameter + base from product
        {
            SHIPPING_COST = Shipping_Cost;
            DISCOUNT = Discount;
        }
        public double SHIPPING_COST//property for SHIPPING_COST
        {
            set
            {
                if (value >= 0)
                    Shipping_Cost = value;
                else
                {
                    Console.WriteLine("Error value");
                    Shipping_Cost = 0;
                }
            }
            get { return Shipping_Cost; }
        }
        public double DISCOUNT//property for DISCOUNT
        {
            set
            {
                if (value >= 0)
                    Discount = value;
                else
                {
                    Console.WriteLine("error value");
                    Discount = 0;
                }
            }
            get { return Discount; }
        }
        public override double CalculatePrice()//override method
        {
            return (Price + Shipping_Cost) - Discount;
        }
        public override void DisplayInfo()//override method(display)
        {
            Console.Write("ID: " + Id + " name:" + Name + " Price:" + Price);
            Console.WriteLine("Shipping Cost:" + Shipping_Cost + " Discount:" + Discount + " final Price: " + CalculatePrice());
        }
    }
}   
