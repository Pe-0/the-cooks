using System;

namespace Project
{
    public class Driver
    {
        protected int Id;
        protected string Name;
        protected string Region;
        protected Warehouse warehouse;
        protected Order currentOrder;

        public Driver()
        {
            Id = 0;
            Name = "No Name";
            Region = "Unknown";
            warehouse = null;
            currentOrder = null;
        }

        public Driver(int id, string name, string region, Warehouse w)
        {
            ID = id;
            NAME = name;
            REGION = region;
            warehouse = w;
            currentOrder = null;
        }

        public int ID
        {
            set
            {
                if (value >= 0)
                    Id = value;
                else
                {
                    Id = 0;
                    Console.WriteLine("Error in Driver ID");
                }
            }
            get { return Id; }
        }

        public string NAME
        {
            set { Name = value; }
            get { return Name; }
        }

        public string REGION
        {
            set { Region = value; }
            get { return Region; }
        }

        public void AssignWarehouse(Warehouse w)
        {
            warehouse = w;
        }

        public void DeliverOrder(Order o, string productType)
        {
            if (o == null)
            {
                Console.WriteLine("No order to deliver.");
                return;
            }

            if (warehouse == null)
            {
                Console.WriteLine("No warehouse assigned to driver.");
                return;
            }

            currentOrder = o;

            Console.WriteLine("Driver " + Name + " is delivering order for customer: " + o.NAME);
            Console.WriteLine("Region: " + o.REGION);

            if (productType == "phone")
            {
                warehouse.DecrementPhone();
            }
            else if (productType == "pc")
            {
                warehouse.DecrementPc();
            }
            else if (productType == "laptop")
            {
                warehouse.DecrementLaptop();
            }
            else
            {
                Console.WriteLine("Unknown product type.");
            }

            Console.WriteLine("Final price of order: " + o.CalculateTotal(o.PRICEP, o.SHIPPING_COST, o.DISCOUNT));
        }

        public void Display()
        {
            Console.WriteLine("Driver Info");
            Console.WriteLine("ID: " + Id + " Name: " + Name + " Region: " + Region);
        }
    }
}
