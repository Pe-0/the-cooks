using System;

namespace Project
{
    // Base Class DriveSchedule
    public class DriveSchedule
    {
        protected int ScheduleId;
        protected string DriverName;
        protected DateTime StartTime;
        protected DateTime EndTime;
        protected double BaseFare;

        public DriveSchedule()
        {
            ScheduleId = 0;
            DriverName = "Unknown";
            StartTime = DateTime.Now;
            EndTime = DateTime.Now.AddHours(1);
            BaseFare = 50;
        }

        public DriveSchedule(int scheduleId, string driverName, DateTime start, DateTime end, double baseFare)
        {
            SCHEDULE_ID = scheduleId;
            DRIVER_NAME = driverName;
            START_TIME = start;
            END_TIME = end;
            BASE_FARE = baseFare;
        }

        public int SCHEDULE_ID
        {
            set { ScheduleId = value; }
            get { return ScheduleId; }
        }

        public string DRIVER_NAME
        {
            set { DriverName = value; }
            get { return DriverName; }
        }

        public DateTime START_TIME
        {
            set { StartTime = value; }
            get { return StartTime; }
        }

        public DateTime END_TIME
        {
            set { EndTime = value; }
            get { return EndTime; }
        }

        public double BASE_FARE
        {
            set
            {
                if (value >= 0)
                    BaseFare = value;
                else
                {
                    BaseFare = 50;
                    Console.WriteLine("Error: Base fare must be non-negative");
                }
            }
            get { return BaseFare; }
        }

        public virtual double CalculateCost()
        {
            return BaseFare;
        }

        public virtual void Display()
        {
            Console.WriteLine("Schedule ID: " + ScheduleId + " Driver: " + DriverName + " Start: " + StartTime + " End: " + EndTime + " Cost: " + CalculateCost());
        }
    }

    // Derived Class: DeliverySchedule
    public class DeliverySchedule : DriveSchedule
    {
        private double PackageWeight;

        public DeliverySchedule() : base()
        {
            PackageWeight = 0;
        }

        public DeliverySchedule(int scheduleId, string driverName, DateTime start, DateTime end, double baseFare, double weight)
            : base(scheduleId, driverName, start, end, baseFare)
        {
            PACKAGE_WEIGHT = weight;
        }

        public double PACKAGE_WEIGHT
        {
            set
            {
                if (value >= 0)
                    PackageWeight = value;
                else
                {
                    PackageWeight = 0;
                    Console.WriteLine("Error: Weight must be non-negative");
                }
            }
            get { return PackageWeight; }
        }

        public override double CalculateCost()
        {
            return BASE_FARE + (PackageWeight * 2);
        }

        public override void Display()
        {
            base.Display();
            Console.WriteLine("Package Weight: " + PackageWeight + " Final Cost: " + CalculateCost());
        }
    }

    // Derived Class: CustomerPickup
    public class CustomerPickup : DriveSchedule
    {
        private double PickupFee;

        public CustomerPickup() : base()
        {
            PickupFee = 20;
        }

        public CustomerPickup(int scheduleId, string driverName, DateTime start, DateTime end, double baseFare, double fee)
            : base(scheduleId, driverName, start, end, baseFare)
        {
            PICKUP_FEE = fee;
        }

        public double PICKUP_FEE
        {
            set
            {
                if (value >= 0)
                    PickupFee = value;
                else
                {
                    PickupFee = 20;
                    Console.WriteLine("Error: Pickup fee must be non-negative");
                }
            }
            get { return PickupFee; }
        }

        public override double CalculateCost()
        {
            return BASE_FARE + PickupFee;
        }

        public override void Display()
        {
            base.Display();
            Console.WriteLine("Pickup Fee: " + PickupFee + " Final Cost: " + CalculateCost());
        }
    }
}
